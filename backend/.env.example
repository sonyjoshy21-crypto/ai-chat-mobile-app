# Server Configuration
PORT=5000

# Database Configuration
# Replace with your MongoDB Connection string. For local testing, a standard local URI or an empty string triggers mock database storage.
MONGODB_URI=mongodb://localhost:27017/ai_chat_db

# Security
JWT_SECRET=super_secret_token_change_in_production

# AI Config (Optional: falls back to intelligent responsive mock mode if left empty)
GEMINI_API_KEY=
